---
import Layout from '../layouts/Layout.astro';

const rawTitle = "About me | Emilia Arriaga";
const title = typeof rawTitle === 'string' ? rawTitle : String(rawTitle ?? 'About me');
---

<Layout title={title}>

  <div class="fixed inset-0 -z-30 paper-base"></div>
  <div class="fixed inset-0 -z-30 papergrain" aria-hidden="true"></div>
  <div id="brown-layer" class="fixed inset-0 -z-29 brown-base opacity-0 transition-opacity duration-[1500ms]"></div>
  <div class="fixed inset-0 pointer-events-none -z-20 bg-[radial-gradient(circle_at_center,_transparent_30%,_rgba(120,100,75,0.12)_100%)]"></div>

  <!-- Drifting ambient background elements -->
  <div class="ambient pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <span class="drift drift-1"></span>
    <span class="drift drift-2"></span>
    <span class="drift drift-3"></span>
    <span class="dust dust-1"></span>
    <span class="dust dust-2"></span>
    <span class="dust dust-3"></span>
    <span class="dust dust-4"></span>
    <span class="dust dust-5"></span>
  </div>

  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <filter id="torn-edge" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="3" seed="9" result="noise" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="10" xChannelSelector="R" yChannelSelector="G" />
    </filter>
    <filter id="torn-edge-photo" x="-6%" y="-6%" width="112%" height="112%">
      <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" seed="4" result="noise" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="7" xChannelSelector="R" yChannelSelector="G" />
    </filter>
    <filter id="torn-edge-note" x="-10%" y="-10%" width="120%" height="120%">
      <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="3" seed="15" result="noise" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="8" xChannelSelector="R" yChannelSelector="G" />
    </filter>
  </svg>

  <main class="w-full relative selection:bg-velvet selection:text-paper">

    <section class="min-h-screen px-6 md:px-16 py-24 relative">

      <div class="text-center mb-6 relative z-30">
        <p class="font-heading text-xs tracking-[0.35em] uppercase mb-4 animate-fade-in-up delay-1">About</p>
        <h1 class="font-heading italic font-bold tracking-wide leading-[0.95]">
          <span class="block text-4xl md:text-6xl animate-fade-in-up delay-2">The engineer</span>
          <span class="itgirl block mt-3">
            <span class="itgirl-star">✦</span>
            <span class="itgirl-text">IT girl</span>
            <span class="itgirl-star">✦</span>
          </span>
        </h1>
        <svg class="flourish mx-auto mt-6 animate-fade-in-up delay-4" width="90" height="14" viewBox="0 0 90 14" aria-hidden="true">
          <path d="M2,7 Q22,1 45,7 Q68,13 88,7" />
          <circle cx="45" cy="7" r="1.6" />
        </svg>
      </div>

      <!-- White flower bouquet -->
      <svg class="bouquet" viewBox="0 0 500 400" aria-hidden="true">
        <g class="bouquet-stem">
          <path d="M250,400 C240,320 260,260 250,190" stroke="#e8e2d0" stroke-width="6" fill="none" opacity="0.5"/>
          <path d="M250,400 C260,340 235,280 245,220" stroke="#e8e2d0" stroke-width="5" fill="none" opacity="0.4"/>
        </g>
        <g class="bouquet-leaf">
          <path d="M240,300 Q180,280 170,330 Q220,340 240,300 Z" fill="#dcd6bd" opacity="0.55"/>
          <path d="M260,270 Q320,250 330,300 Q280,310 260,270 Z" fill="#e2dcc4" opacity="0.5"/>
        </g>
        <g class="flower-1">
          <g class="petal-spin">
            <ellipse cx="230" cy="150" rx="55" ry="30" fill="#fdfbf5" opacity="0.92" transform="rotate(0 230 150)"/>
            <ellipse cx="230" cy="150" rx="55" ry="30" fill="#fdfbf5" opacity="0.92" transform="rotate(60 230 150)"/>
            <ellipse cx="230" cy="150" rx="55" ry="30" fill="#fdfbf5" opacity="0.92" transform="rotate(120 230 150)"/>
            <ellipse cx="230" cy="150" rx="55" ry="30" fill="#fdfbf5" opacity="0.92" transform="rotate(180 230 150)"/>
            <ellipse cx="230" cy="150" rx="55" ry="30" fill="#fdfbf5" opacity="0.92" transform="rotate(240 230 150)"/>
            <ellipse cx="230" cy="150" rx="55" ry="30" fill="#fdfbf5" opacity="0.92" transform="rotate(300 230 150)"/>
            <circle cx="230" cy="150" r="14" fill="#e9c98a"/>
          </g>
        </g>
        <g class="flower-2">
          <g class="petal-spin petal-spin--slow">
            <ellipse cx="350" cy="90" rx="38" ry="20" fill="#fdfbf5" opacity="0.88" transform="rotate(0 350 90)"/>
            <ellipse cx="350" cy="90" rx="38" ry="20" fill="#fdfbf5" opacity="0.88" transform="rotate(60 350 90)"/>
            <ellipse cx="350" cy="90" rx="38" ry="20" fill="#fdfbf5" opacity="0.88" transform="rotate(120 350 90)"/>
            <ellipse cx="350" cy="90" rx="38" ry="20" fill="#fdfbf5" opacity="0.88" transform="rotate(180 350 90)"/>
            <ellipse cx="350" cy="90" rx="38" ry="20" fill="#fdfbf5" opacity="0.88" transform="rotate(240 350 90)"/>
            <ellipse cx="350" cy="90" rx="38" ry="20" fill="#fdfbf5" opacity="0.88" transform="rotate(300 350 90)"/>
            <circle cx="350" cy="90" r="10" fill="#e9c98a"/>
          </g>
        </g>
        <g class="flower-3">
          <g class="petal-spin petal-spin--fast">
            <ellipse cx="130" cy="80" rx="30" ry="16" fill="#fdfbf5" opacity="0.85" transform="rotate(0 130 80)"/>
            <ellipse cx="130" cy="80" rx="30" ry="16" fill="#fdfbf5" opacity="0.85" transform="rotate(60 130 80)"/>
            <ellipse cx="130" cy="80" rx="30" ry="16" fill="#fdfbf5" opacity="0.85" transform="rotate(120 130 80)"/>
            <ellipse cx="130" cy="80" rx="30" ry="16" fill="#fdfbf5" opacity="0.85" transform="rotate(180 130 80)"/>
            <ellipse cx="130" cy="80" rx="30" ry="16" fill="#fdfbf5" opacity="0.85" transform="rotate(240 130 80)"/>
            <ellipse cx="130" cy="80" rx="30" ry="16" fill="#fdfbf5" opacity="0.85" transform="rotate(300 130 80)"/>
            <circle cx="130" cy="80" r="8" fill="#e9c98a"/>
          </g>
        </g>
      </svg>

      <!-- Binder rings -->
      <div class="binder-rings" aria-hidden="true">
        <span class="ring"></span>
        <span class="ring"></span>
        <span class="ring"></span>
        <span class="ring"></span>
        <span class="ring"></span>
        <span class="ring"></span>
      </div>

      <div id="moodboard" class="moodboard max-w-6xl mx-auto mt-4">

        <div class="mb-item mb-photo-lg mb-1" data-mb>
          <div class="flip-inner">
            <div class="flip-front">
              <img src="/images/about/photo-1.jpg" alt="" />
              <span class="pin"></span>
            </div>
            <div class="flip-back">
              <p>This was taken during finals week — proof that chaos and focus can coexist.</p>
            </div>
          </div>
        </div>

        <div class="mb-item mb-swatch mb-2" data-mb>
          <div class="swatch-inner">
            <p class="swatch-label">Personal Record</p>
            <p class="swatch-title">Emilia Macarena<br/>Arriaga Rodriguez</p>
            <div class="swatch-rule"></div>
            <p class="swatch-body">
              Computational Engineering<br/>
              8th Semester — UNAM<br/>
              Building systems out of chaos.
            </p>
          </div>
        </div>

        <div class="mb-item mb-photo-md mb-3" data-mb>
          <div class="flip-inner">
            <div class="flip-front">
              <img src="/images/about/photo-2.jpg" alt="" />
              <span class="pin"></span>
            </div>
            <div class="flip-back">
              <p>Somewhere between a debugging session and an existential crisis about semicolons.</p>
            </div>
          </div>
        </div>

        <div class="mb-item mb-note mb-4" data-mb>
          <p>
            Tools change, logic is eternal. Currently chasing <em>ethical hacking</em>, secure systems, and applying technical work toward the common good.
          </p>
        </div>

        <div class="mb-item mb-photo-sm mb-5" data-mb>
          <div class="flip-inner">
            <div class="flip-front">
              <img src="/images/about/photo-3.jpg" alt="" />
              <span class="pin"></span>
            </div>
            <div class="flip-back">
              <p>Three words that describe me, mid-sentence: logic, spontaneity, impact.</p>
            </div>
          </div>
        </div>

        <div class="mb-item mb-photo-wide mb-6" data-mb>
          <div class="flip-inner">
            <div class="flip-front">
              <img src="/images/about/photo-4.jpg" alt="" />
              <span class="pin"></span>
            </div>
            <div class="flip-back">
              <p>Ethical hacking club meeting — we broke something on purpose, then fixed it better.</p>
            </div>
          </div>
        </div>

        <div class="mb-item mb-photo-sm mb-7" data-mb>
          <div class="flip-inner">
            <div class="flip-front">
              <img src="/images/about/photo-5.jpg" alt="" />
              <span class="pin"></span>
            </div>
            <div class="flip-back">
              <p>Design is never finished, only iterated — same goes for this outfit.</p>
            </div>
          </div>
        </div>

      </div>

    </section>

    <section id="spotify-section" class="min-h-screen px-6 py-24 flex flex-col justify-center items-center text-center relative z-10">

      <div class="relative mb-16 flex flex-col items-center animate-fade-in-up">
          <p class="font-heading-dark text-xs tracking-[0.35em] uppercase mb-4">On Repeat</p>
          <h2 class="font-heading-dark text-5xl md:text-6xl italic font-bold tracking-wide relative z-10 px-8">
            What's Playing
          </h2>
          <svg class="flourish-dark mx-auto mt-4" width="90" height="14" viewBox="0 0 90 14" aria-hidden="true">
            <path d="M2,7 Q22,1 45,7 Q68,13 88,7" />
            <circle cx="45" cy="7" r="1.6" />
          </svg>
      </div>

      <div id="spotify-wrap" class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <p class="font-heading-dark text-sm italic mb-6 opacity-70">Recently Streamed</p>
          <div id="spotify-tracks" class="space-y-3 text-left">
            <p class="font-sans text-sm opacity-50">Loading...</p>
          </div>
        </div>
        <div>
          <p class="font-heading-dark text-sm italic mb-6 opacity-70">Most Streamed Artist</p>
          <div id="spotify-artist" class="text-left">
            <p class="font-sans text-sm opacity-50">Loading...</p>
          </div>
        </div>
      </div>

    </section>

    <footer class="w-full py-12 text-center relative z-10">
        <p class="font-sans text-xs tracking-widest opacity-60 uppercase footer-text">
            Developed with <span class="text-velvet text-lg align-middle">♥</span> by <span class="font-heading-dark italic text-lg normal-case">Macarena</span>
        </p>
    </footer>

  </main>
</Layout>

<script>
  async function loadSpotify() {
    const tracksEl = document.getElementById('spotify-tracks');
    const artistEl = document.getElementById('spotify-artist');
    if (!tracksEl || !artistEl) return;

    try {
      const res = await fetch('/api/spotify');
      const data = await res.json();

      if (data.tracks && data.tracks.length) {
        tracksEl.innerHTML = data.tracks.map(t => `
          <a href="${t.url}" target="_blank" class="spotify-track">
            <img src="${t.albumArt}" alt="" />
            <div>
              <p class="track-name">${t.name}</p>
              <p class="track-artist">${t.artist}</p>
            </div>
          </a>
        `).join('');
      } else {
        tracksEl.innerHTML = `<p class="font-sans text-sm opacity-50">No recent tracks found.</p>`;
      }

      if (data.topArtist) {
        artistEl.innerHTML = `
          <a href="${data.topArtist.url}" target="_blank" class="spotify-artist">
            <img src="${data.topArtist.image}" alt="" />
            <p class="artist-name">${data.topArtist.name}</p>
          </a>
        `;
      } else {
        artistEl.innerHTML = `<p class="font-sans text-sm opacity-50">No top artist found.</p>`;
      }
    } catch (err) {
      tracksEl.innerHTML = `<p class="font-sans text-sm opacity-50">Couldn't load Spotify data.</p>`;
      artistEl.innerHTML = '';
    }
  }

  loadSpotify();
  document.addEventListener('astro:page-load', loadSpotify);
</script>

<script>
  function initMoodboard() {
    const items = document.querySelectorAll('#moodboard [data-mb]');
    if (!items.length) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('mb-in');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    items.forEach((item) => obs.observe(item));
  }

  function initBrownTransition() {
    const brownLayer = document.getElementById('brown-layer');
    const trigger = document.getElementById('spotify-section');
    if (!brownLayer || !trigger) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          brownLayer.classList.remove('opacity-0');
          brownLayer.classList.add('opacity-100');
        } else {
          brownLayer.classList.remove('opacity-100');
          brownLayer.classList.add('opacity-0');
        }
      });
    }, { threshold: 0.3 });

    obs.observe(trigger);
  }

  initMoodboard();
  initBrownTransition();
  document.addEventListener('astro:page-load', () => {
    initMoodboard();
    initBrownTransition();
  });
</script>

<style is:global>
  .animate-fade-in-up {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeInUp 1.2s cubic-bezier(0.2,0.8,0.2,1) forwards;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.4s; }
  .delay-4 { animation-delay: 1.6s; }
  @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

  /* ---- Paper background (default) ---- */
  .paper-base {
    background:
      radial-gradient(ellipse 80% 60% at 30% 10%, rgba(255,255,255,0.5), transparent 60%),
      radial-gradient(ellipse 70% 50% at 80% 90%, rgba(180,160,120,0.15), transparent 60%),
      linear-gradient(165deg, #f7f2e4 0%, #efe8d4 40%, #e6ddc4 100%);
  }
  .papergrain {
    opacity: 0.12;
    mix-blend-mode: multiply;
    background-image:
      repeating-linear-gradient(3deg, rgba(0,0,0,0.03) 0px, rgba(0,0,0,0.03) 1px, transparent 1px, transparent 3px),
      radial-gradient(circle at 25% 35%, rgba(0,0,0,0.03), transparent 40%),
      radial-gradient(circle at 75% 65%, rgba(0,0,0,0.025), transparent 45%);
  }

  /* ---- Brown overlay, fades in for Spotify section ---- */
  .brown-base {
    background:
      radial-gradient(ellipse 90% 70% at 25% 15%, rgba(90,70,55,0.35), transparent 65%),
      radial-gradient(ellipse 80% 60% at 80% 85%, rgba(40,28,22,0.4), transparent 65%),
      linear-gradient(165deg, #6b5644 0%, #574636 32%, #453626 62%, #362a1e 100%);
  }

  .font-heading {
    font-family: 'Playfair Display', serif;
    color: #3a2e22;
    text-shadow: 0 1px 2px rgba(255,255,255,0.4);
  }
  .font-heading-dark {
    font-family: 'Playfair Display', serif;
    color: #f2e9d4;
    text-shadow: 0 0 14px rgba(230,200,150,0.3), 0 1px 3px rgba(0,0,0,0.5);
  }
  h1 {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .flourish path, .flourish circle { stroke: #a4645a; fill: none; stroke-width: 1; opacity: 0.6; }
  .flourish circle { fill: #a4645a; stroke: none; }
  .flourish-dark path, .flourish-dark circle { stroke: #d9a4a0; fill: none; stroke-width: 1; opacity: 0.6; }
  .flourish-dark circle { fill: #d9a4a0; stroke: none; }
  .footer-text { color: #3a2e22; }

  /* ---- IT girl ---- */
  .itgirl {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    font-size: clamp(2rem, 6vw, 5rem);
    opacity: 0;
    transform: translateY(20px) scale(0.9);
    animation: itgirlIn 1.4s cubic-bezier(0.16,1,0.3,1) 0.7s forwards;
  }
  .itgirl-text {
    min-width: 0;
    color: #722F37;
    text-shadow: 0 0 24px rgba(114,47,55,0.25), 0 2px 4px rgba(0,0,0,0.15);
    animation: itgirlGlow 4s ease-in-out 2.1s infinite;
    white-space: normal;
  }
  @media (max-width: 900px) {
    .itgirl { gap: 0.35rem; font-size: clamp(1.8rem, 8vw, 4rem); }
  }
  @keyframes itgirlIn {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes itgirlGlow {
    0%, 100% { text-shadow: 0 0 24px rgba(114,47,55,0.25), 0 2px 4px rgba(0,0,0,0.15); }
    50% { text-shadow: 0 0 38px rgba(114,47,55,0.4), 0 2px 4px rgba(0,0,0,0.15); }
  }
  .itgirl-star {
    display: inline-block;
    color: #a4645a;
    font-size: 0.5em;
    animation: spin 12s linear infinite;
  }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  /* ---- White flower bouquet ---- */
  .bouquet {
    position: absolute;
    top: -20px;
    right: -40px;
    width: 340px;
    height: 260px;
    z-index: 15;
    pointer-events: none;
    filter: drop-shadow(2px 6px 10px rgba(60,45,30,0.15));
  }
  @media (max-width: 900px) {
    .bouquet { width: 200px; height: 160px; top: -5px; right: -20px; }
  }
  .petal-spin {
    transform-origin: center;
    animation: petalSway 8s ease-in-out infinite;
  }
  .petal-spin--slow { animation-duration: 11s; animation-delay: 0.5s; }
  .petal-spin--fast { animation-duration: 6.5s; animation-delay: 1s; }
  @keyframes petalSway {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(6deg); }
  }
  .bouquet-stem, .bouquet-leaf {
    animation: stemSway 9s ease-in-out infinite;
    transform-origin: bottom center;
  }
  @keyframes stemSway {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-2deg); }
  }

  /* ---- Binder rings ---- */
  .binder-rings {
    display: flex;
    justify-content: center;
    gap: 4.5rem;
    margin: 2.5rem 0 1rem;
    position: relative;
    z-index: 20;
  }
  @media (max-width: 900px) {
    .binder-rings { gap: 2rem; }
  }
  .ring {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 5px solid #c9c0a3;
    background: radial-gradient(circle at 35% 30%, #fdfbf5, #d8cfb2 70%);
    box-shadow:
      inset 0 2px 3px rgba(0,0,0,0.15),
      0 3px 5px rgba(0,0,0,0.2);
    position: relative;
  }
  .ring::after {
    content: '';
    position: absolute;
    inset: 8px;
    border-radius: 50%;
    background: #f7f2e4;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.2);
  }

  /* ---- Ambient drifting background ---- */
  .drift {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.18;
  }
  .drift-1 {
    width: 40vw; height: 40vw; top: -5%; left: -8%;
    background: radial-gradient(circle, rgba(164,100,90,0.5), transparent 70%);
    animation: driftMove 30s ease-in-out infinite;
  }
  .drift-2 {
    width: 35vw; height: 35vw; bottom: -10%; right: -10%;
    background: radial-gradient(circle, rgba(124,138,104,0.4), transparent 70%);
    animation: driftMove 36s ease-in-out infinite reverse;
  }
  .drift-3 {
    width: 30vw; height: 30vw; top: 45%; left: 60%;
    background: radial-gradient(circle, rgba(217,169,160,0.35), transparent 70%);
    animation: driftMove 26s ease-in-out infinite;
  }
  @keyframes driftMove {
    0%, 100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(5vw, 4vh) scale(1.08); }
    66% { transform: translate(-4vw, 6vh) scale(0.94); }
  }

  .dust {
    position: absolute;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(90,70,50,0.6), transparent 70%);
    opacity: 0;
    animation-name: dustFloat;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .dust-1 { left: 12%; animation-duration: 14s; animation-delay: 0s; }
  .dust-2 { left: 30%; animation-duration: 18s; animation-delay: 3s; }
  .dust-3 { left: 55%; animation-duration: 16s; animation-delay: 6s; }
  .dust-4 { left: 72%; animation-duration: 20s; animation-delay: 2s; }
  .dust-5 { left: 88%; animation-duration: 15s; animation-delay: 8s; }
  @keyframes dustFloat {
    0% { bottom: -5%; opacity: 0; transform: translateX(0); }
    10% { opacity: 0.6; }
    50% { transform: translateX(20px); }
    90% { opacity: 0.3; }
    100% { bottom: 105%; opacity: 0; transform: translateX(-15px); }
  }

  /* ---- Moodboard ---- */
  .moodboard {
    position: relative;
    height: 980px;
  }
  @media (max-width: 900px) {
    .moodboard {
      height: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      padding: 1rem 0;
    }
  }

  .mb-item {
    position: absolute;
    perspective: 1200px;
    opacity: 0;
    transform: translateY(40px) scale(0.92) rotate(var(--mb-rot, 0deg));
    transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
  }
  .mb-item.mb-in {
    opacity: 1;
    transform: translateY(0) scale(1) rotate(var(--mb-rot, 0deg));
  }
  @media (max-width: 900px) {
    .mb-item {
      position: static;
      transform: none !important;
      width: 300px !important;
      height: auto !important;
      opacity: 1;
    }
  }


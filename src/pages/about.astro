---
import Layout from '../layouts/Layout.astro';

const rawTitle = "About me | Emilia Arriaga";
const title = typeof rawTitle === 'string' ? rawTitle : String(rawTitle ?? 'About me');
---

<Layout title={title}>
  
  <div 
    class="fixed inset-0 bg-gradient-to-br from-[#fffdf5] via-[#f2eee5] to-[#e6dec9] -z-40"
  ></div>

  <div 
    id="wood-layer"
    class="fixed inset-0 opacity-0 transition-opacity duration-[1500ms] -z-30 wood-pattern"
  ></div>

  <div class="fixed inset-0 pointer-events-none z-[-10] bg-[radial-gradient(ellipse_at_center,_transparent_20%,_rgba(40,30,20,0.3)_100%)] mix-blend-multiply"></div>

  <main class="w-full relative selection:bg-velvet selection:text-paper">

    <section class="min-h-screen flex flex-col justify-center px-6 md:px-24 py-24 relative overflow-hidden" data-theme="light">
      <div class="absolute left-6 md:left-12 top-0 bottom-0 w-[1px] bg-bruise/10"></div>
      <div class="absolute top-12 right-6 md:right-12 font-sans text-xs tracking-widest text-bruise/40">P.01 — INTRO</div>
      
      <div class="flex items-center justify-center md:justify-start gap-6 mb-24 animate-fade-in-up">
          <div class="h-[1px] bg-bruise/30 w-12 md:w-24 hidden md:block"></div>
          <h1 class="font-serif text-6xl md:text-8xl text-ink text-center leading-[0.9] drop-shadow-xl">
              The engineer<br>
              <span class="font-bold italic text-velvet text-5xl md:text-7xl relative top-4 flex items-center justify-center gap-4 drop-shadow-md">
                  <svg class="w-6 h-6 md:w-8 md:h-8 animate-spin-slow opacity-80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z" fill="currentColor"/>
                  </svg>
                  IT girl
                  <svg class="w-6 h-6 md:w-8 md:h-8 animate-spin-slow opacity-80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z" fill="currentColor"/>
                  </svg>
              </span>
          </h1>
          <div class="h-[1px] bg-bruise/30 w-12 md:w-24 hidden md:block"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div class="space-y-6 text-lg md:text-xl font-sans font-light text-bruise leading-relaxed max-w-lg animate-fade-in-up delay-200 text-left mx-auto md:ml-24">
              <p>
                Hello! My name is <span class="text-ink font-normal border-b border-velvet/30 pb-0.5">Emilia Macarena Arriaga Rodriguez</span>.
              </p>
              <p>
                Tools change, but logic is eternal. I am a <span class="text-ink font-normal border-b border-velvet/30 pb-0.5">Computational Engineering</span> student learning to dismantle real-life problems and rebuild them as functioning systems.
              </p>
              
              <div class="flex items-center gap-4 pt-6 opacity-60 font-mono text-xs uppercase tracking-widest">
              </div>

              <div class="mt-4">
                <p class="mb-2">
                  I am currently studying at the <span class="text-ink font-normal border-b border-velvet/30 pb-0.5">National Autonomous University of Mexico</span>, in the eighth semester. Key coursework includes:
                </p>
                <ul class="list-disc pl-5 space-y-1 marker:text-velvet/50">
                  <li>Data Structures and Algorithms</li>
                  <li>Databases</li>
                  <li>Cybersecurity</li>
                  <li>Artificial Intelligence</li>
                  <li>Economy</li>
                  <li>Statistics</li>
                  <li>Software Engineering</li>
                </ul>
              </div>

              <div class="bottom-left-text" style="text-align: right; margin-left: auto; margin-right: 0; margin-top: 60px; max-width: 350px;">
                <p>
                    Design is never finished, only iterated. 
                    I am currently looking for opportunities to 
                    apply <span class="text-ink font-normal border-b border-velvet/30 pb-0.5">secure coding</span> 
                    practices in real-world environments.
                </p>
            </div>
          </div>

          <div class="flex flex-col gap-8 max-w-md mx-auto">
                <div class="relative w-full aspect-[2/3] overflow-hidden group animate-fade-in-up delay-300 border-2 border-ink/80 p-1 bg-paper shadow-[5px_5px_0px_rgba(42,42,42,0.2)]">
                    <div class="w-full h-full overflow-hidden relative grayscale group-hover:grayscale-0 transition-all duration-[2000ms]">
                        <img 
                          src="/mered.png" 
                          class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-[2000ms]"
                          style="object-position: center top;" 
                        />
                        <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-30 mix-blend-overlay"></div>
                    </div>
                    <div class="absolute -bottom-8 right-0 font-serif italic text-ink/60 text-xs">
                        Ref: 001
                    </div>
                </div>

                <div class="animate-fade-in-up delay-300 pl-4 border-l border-bruise/20">
                    <p class="font-sans text-sm md:text-base text-bruise/80 leading-relaxed text-justify">
                        Beyond the binary, there is intent. I design systems that anticipate the chaos of the real world, finding the precise balance between <span class="text-velvet italic font-serif">structure</span> and <span class="text-velvet italic font-serif">efficiency</span>.
                    </p>
                </div>
            </div>
          </div>
    </section>

    <section class="trigger-dark-mode min-h-[150vh] flex flex-col items-center px-6 relative pt-40 pb-40">
      
      <div class="relative text-center mb-24 z-10">
        <div class="flex justify-center mb-6 text-[#fffdf5]/80 drop-shadow-xl"> 
            <svg class="animate-spin-slow w-8 h-8" viewBox="0 0 24 24" fill="none">
                <path d="M12 0L14.5 9.5L24 12L14.5 14.5L12 24L9.5 14.5L0 12L9.5 9.5L12 0Z" fill="currentColor"/>
            </svg>
        </div>
        
        <p class="font-sans text-xs tracking-[0.3em] uppercase text-[#fffdf5]/80 mb-4 drop-shadow-xl">The Origin</p>
        
        <h2 class="font-serif text-5xl md:text-7xl italic text-[#fffdf5] transition-colors duration-1000 drop-shadow-xl">
          Why I chose to<br>speak in binary.
        </h2>
      </div>

      <div class="max-w-2xl w-full space-y-32 z-20">
        
        <div class="relative p-12 paper-card">
            <div class="absolute top-4 left-4 w-8 h-8 border-t-[2px] border-l-[2px] border-bruise/80 rounded-tl-2xl"></div>
            <div class="absolute top-4 right-4 w-8 h-8 border-t-[2px] border-r-[2px] border-bruise/80 rounded-tr-2xl"></div>
            <div class="absolute bottom-4 left-4 w-8 h-8 border-b-[2px] border-l-[2px] border-bruise/80 rounded-bl-2xl"></div>
            <div class="absolute bottom-4 right-4 w-8 h-8 border-b-[2px] border-r-[2px] border-bruise/80 rounded-br-2xl"></div>

            <p class="font-sans text-ink/90 leading-loose text-lg text-center px-4 relative z-10">
                My journey into engineering began with a fundamental curiosity: to understand not just what technology does, but <span class="text-velvet font-serif italic text-xl">how</span> it functions. Since a young age, I have been driven by a necessity to look past the user interface and comprehend the complex logic that powers our modern world.
            </p>
        </div>
        
        <div class="relative h-40 w-full flex justify-center items-center group cursor-help py-4">
            
            <div class="absolute inset-0 flex justify-center items-center transition-all duration-700 group-hover:opacity-0 group-hover:scale-95 group-hover:blur-sm">
                <span class="font-serif italic text-3xl md:text-4xl text-[#fffdf5] tracking-widest border-b-2 border-[#fffdf5]/40 pb-2 drop-shadow-[0_0_15px_rgba(255,253,245,0.6)]">
                    Three words that describe me
                </span>
            </div>

            <div class="absolute inset-0 flex flex-col md:flex-row justify-center items-center gap-4 md:gap-12 opacity-0 scale-105 blur-sm transition-all duration-700 group-hover:opacity-100 group-hover:scale-100 group-hover:blur-0">
                 <span class="font-serif italic text-2xl md:text-3xl text-[#fffdf5] drop-shadow-xl tracking-wider">Logic</span>
                 <span class="hidden md:block text-[#fffdf5]/40 text-xs">✦</span>
                 <span class="font-serif italic text-2xl md:text-3xl text-[#fffdf5] drop-shadow-xl tracking-wider">Spontainety</span>
                 <span class="hidden md:block text-[#fffdf5]/40 text-xs">✦</span>
                 <span class="font-serif italic text-2xl md:text-3xl text-[#fffdf5] drop-shadow-xl tracking-wider">Impact</span>
            </div>
        </div>

        <div class="relative p-12 paper-card">
            <div class="absolute top-4 left-4 w-8 h-8 border-t-[2px] border-l-[2px] border-bruise/80 rounded-tl-2xl"></div>
            <div class="absolute top-4 right-4 w-8 h-8 border-t-[2px] border-r-[2px] border-bruise/80 rounded-tr-2xl"></div>
            <div class="absolute bottom-4 left-4 w-8 h-8 border-b-[2px] border-l-[2px] border-bruise/80 rounded-bl-2xl"></div>
            <div class="absolute bottom-4 right-4 w-8 h-8 border-b-[2px] border-r-[2px] border-bruise/80 rounded-br-2xl"></div>

            <p class="font-sans text-ink/90 leading-loose text-lg text-center px-4 relative z-10">
                Today, that curiosity has evolved into a clear purpose. I view Computational Engineering as a toolkit for social impact. My goal is to design robust, secure systems that solve tangible problems, translating technical expertise into solutions that serve the greater <span class="text-velvet font-serif italic text-xl">common good</span>.
            </p>
        </div>

      </div>
    </section>

    <section class="min-h-screen px-6 py-24 flex flex-col justify-center items-center text-center relative z-10 bg-transparent overflow-hidden">
      
      <div class="relative mb-20 flex flex-col items-center">
          <p class="font-heading text-xs tracking-[0.35em] uppercase mb-4">Kept Company</p>
          <h2 class="font-heading text-5xl md:text-6xl italic font-bold tracking-wide relative z-10 px-8">
            Faces I Keep Close
          </h2>
          <svg class="flourish mx-auto mt-4" width="90" height="14" viewBox="0 0 90 14" aria-hidden="true">
            <path d="M2,7 Q22,1 45,7 Q68,13 88,7" />
            <circle cx="45" cy="7" r="1.6" />
          </svg>
      </div>

      <div class="clothesline-wrap w-full max-w-5xl">
        <div class="rope"></div>
        <div class="clothesline">
          <div class="photo-item" style="--sway-dur: 6.5s; --sway-delay: 0s; --rot: -4deg;">
            <span class="pin"></span>
            <img src="/images/gallery/photo-1.jpg" alt="" />
          </div>
          <div class="photo-item" style="--sway-dur: 7.2s; --sway-delay: 0.4s; --rot: 3deg;">
            <span class="pin"></span>
            <img src="/images/gallery/photo-2.jpg" alt="" />
          </div>
          <div class="photo-item" style="--sway-dur: 5.8s; --sway-delay: 0.9s; --rot: -2deg;">
            <span class="pin"></span>
            <img src="/images/gallery/photo-3.jpg" alt="" />
          </div>
          <div class="photo-item" style="--sway-dur: 6.9s; --sway-delay: 0.2s; --rot: 5deg;">
            <span class="pin"></span>
            <img src="/images/gallery/photo-4.jpg" alt="" />
          </div>
          <div class="photo-item" style="--sway-dur: 6.2s; --sway-delay: 1.1s; --rot: -3deg;">
            <span class="pin"></span>
            <img src="/images/gallery/photo-5.jpg" alt="" />
          </div>
          <div class="photo-item" style="--sway-dur: 7.5s; --sway-delay: 0.6s; --rot: 2deg;">
            <span class="pin"></span>
            <img src="/images/gallery/photo-6.jpg" alt="" />
          </div>
        </div>
      </div>
    </section>

    <section class="min-h-screen px-6 py-24 flex flex-col justify-center items-center text-center relative z-10 bg-transparent">

      <div class="relative mb-16 flex flex-col items-center">
          <p class="font-heading text-xs tracking-[0.35em] uppercase mb-4">On Repeat</p>
          <h2 class="font-heading text-5xl md:text-6xl italic font-bold tracking-wide relative z-10 px-8">
            What's Playing
          </h2>
          <svg class="flourish mx-auto mt-4" width="90" height="14" viewBox="0 0 90 14" aria-hidden="true">
            <path d="M2,7 Q22,1 45,7 Q68,13 88,7" />
            <circle cx="45" cy="7" r="1.6" />
          </svg>
      </div>

      <div id="spotify-wrap" class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <p class="font-heading text-sm italic mb-6 opacity-70">Recently Streamed</p>
          <div id="spotify-tracks" class="space-y-3 text-left">
            <p class="font-sans text-sm opacity-50">Loading...</p>
          </div>
        </div>
        <div>
          <p class="font-heading text-sm italic mb-6 opacity-70">Most Streamed Artist</p>
          <div id="spotify-artist" class="text-left">
            <p class="font-sans text-sm opacity-50">Loading...</p>
          </div>
        </div>
      </div>

    </section>

    <footer class="w-full py-12 text-center relative z-10 mb-12">
        <p class="font-sans text-xs tracking-widest text-bruise/40 uppercase">
            Developed with <span class="text-velvet text-lg align-middle">♥</span> by <span class="font-serif italic text-ink text-lg normal-case">Macarena</span>
        </p>
    </footer>

  </main>
</Layout>

<script>
(function () {
  const woodLayer = () => document.getElementById('wood-layer');
  const trigger = () => document.querySelector('.trigger-dark-mode');

  function setWoodVisible(visible: boolean) {
    const el = woodLayer();
    if (!el) return;
    if (visible) el.classList.remove('opacity-0');
    else el.classList.add('opacity-0');
  }

  function init() {
    const t = trigger();
    const w = woodLayer();
    if (!t || !w) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => setWoodVisible(e.isIntersecting));
    }, { threshold: 0.25, rootMargin: '0px 0px -20% 0px' });

    obs.observe(t);

    setTimeout(() => {
      const rect = t.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;
      const visible = rect.top <= vh * 0.8 && rect.bottom > 0;
      setWoodVisible(visible);
    }, 50);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else init();
  document.addEventListener('astro:page-load', init);
})();
</script>

<script>
  async function loadSpotify() {
    const tracksEl = document.getElementById('spotify-tracks');
    const artistEl = document.getElementById('spotify-artist');
    if (!tracksEl || !artistEl) return;

    try {
      const res = await fetch('/api/spotify');
      const data = await res.json() as {
        tracks?: Array<{
          url: string;
          albumArt: string;
          name: string;
          artist: string;
        }>;
        topArtist?: {
          url: string;
          image: string;
          name: string;
        };
      };

      if (data.tracks && data.tracks.length) {
        tracksEl.innerHTML = data.tracks.map(t => `
          <a href="${t.url}" target="_blank" class="spotify-track">
            <img src="${t.albumArt}" alt="" />
            <div>
              <p class="track-name">${t.name}</p>
              <p class="track-artist">${t.artist}</p>
            </div>
          </a>
        `).join('');
      } else {
        tracksEl.innerHTML = `<p class="font-sans text-sm opacity-50">No recent tracks found.</p>`;
      }

      if (data.topArtist) {
        artistEl.innerHTML = `
          <a href="${data.topArtist.url}" target="_blank" class="spotify-artist">
            <img src="${data.topArtist.image}" alt="" />
            <p class="artist-name">${data.topArtist.name}</p>
          </a>
        `;
      } else {
        artistEl.innerHTML = `<p class="font-sans text-sm opacity-50">No top artist found.</p>`;
      }
    } catch (err) {
      tracksEl.innerHTML = `<p class="font-sans text-sm opacity-50">Couldn't load Spotify data.</p>`;
      artistEl.innerHTML = '';
    }
  }

  loadSpotify();
  document.addEventListener('astro:page-load', loadSpotify);
</script>

<style>
    /* 1. PHYSICAL PAPER CARD STYLE */
    .paper-card {
        background-color: #fdfbf7;
        background-image: url("https://grainy-gradients.vercel.app/noise.svg");
        background-size: 300px;
        background-blend-mode: multiply;
        
        box-shadow: 
            0 20px 40px -5px rgba(0,0,0,0.3),
            inset 0 0 80px rgba(166, 139, 115, 0.15); 
        
        border-top: 1px solid rgba(255,255,255,0.8);
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    /* 2. MILKY MOCHA WOOD TEXTURE */
    .wood-pattern {
        background-color: #6e5c4f; 
        background-image: repeating-linear-gradient(
            45deg,
            rgba(0,0,0,0.05) 0px,
            rgba(0,0,0,0.05) 2px,
            transparent 2px,
            transparent 8px
        ),
        repeating-linear-gradient(
            -45deg,
            rgba(0,0,0,0.03) 0px,
            rgba(0,0,0,0.03) 1px,
            transparent 1px,
            transparent 12px
        );
        box-shadow: inset 0 0 150px rgba(0,0,0,0.7);
    }

    /* ANIMATIONS */
    .animate-fade-in-up {
        animation: fadeInUp 1.5s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    @keyframes fadeInUp {
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-spin-slow { animation: spin 12s linear infinite; }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* ---- Aesthetic match: headings (shared with index) ---- */
    .font-heading {
        font-family: 'Playfair Display', serif;
        color: #4a3a2c;
        text-shadow: 0 1px 2px rgba(0,0,0,0.15);
    }
    .flourish path, .flourish circle {
        stroke: #a4645a;
        fill: none;
        stroke-width: 1;
        opacity: 0.6;
    }
    .flourish circle { fill: #a4645a; stroke: none; }

    /* ---- Clothesline gallery ---- */
    .clothesline-wrap {
        position: relative;
        padding-top: 30px;
    }
    .rope {
        position: absolute;
        top: 0;
        left: 2%;
        right: 2%;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(74,58,44,0.5) 8%, rgba(74,58,44,0.5) 92%, transparent);
    }
    .clothesline {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 2.5rem 2rem;
        padding-top: 10px;
    }
    .photo-item {
        position: relative;
        width: 140px;
        height: 175px;
        transform-origin: top center;
        animation: sway var(--sway-dur) ease-in-out var(--sway-delay) infinite;
    }
    @media (min-width: 768px) {
        .photo-item { width: 170px; height: 210px; }
    }
    @keyframes sway {
        0%, 100% { transform: rotate(var(--rot)); }
        50% { transform: rotate(calc(var(--rot) * -1)); }
    }
    .photo-item:hover {
        animation-play-state: paused;
        transform: rotate(0deg) scale(1.06);
        z-index: 5;
    }
    .pin {
        position: absolute;
        top: -6px;
        left: 50%;
        transform: translateX(-50%);
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 30%, #c9857a, #7a3a35);
        box-shadow: 0 2px 3px rgba(0,0,0,0.4);
        z-index: 2;
    }
    .photo-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border: 6px solid #f5efe0;
        box-shadow: 3px 6px 12px rgba(0,0,0,0.35);
        filter: grayscale(1) contrast(1.05);
        transition: filter 0.6s ease, box-shadow 0.4s ease;
    }
    .photo-item:hover img {
        filter: grayscale(0) contrast(1.05);
        box-shadow: 3px 6px 20px rgba(0,0,0,0.45);
    }

    /* ---- Spotify cards ---- */
    .spotify-track {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.6rem;
        border-bottom: 1px solid rgba(74,58,44,0.12);
        text-decoration: none;
        transition: background 0.3s ease;
    }
    .spotify-track:hover { background: rgba(74,58,44,0.05); }
    .spotify-track img {
        width: 48px; height: 48px; object-fit: cover; flex-shrink: 0;
        box-shadow: 2px 3px 6px rgba(0,0,0,0.25);
    }
    .track-name { font-family: 'Playfair Display', serif; font-style: italic; color: #2a1f1a; }
    .track-artist { font-family: sans-serif; font-size: 0.75rem; opacity: 0.6; }

    .spotify-artist {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
    }
    .spotify-artist img {
        width: 90px; height: 90px; object-fit: cover; border-radius: 50%;
        filter: grayscale(0.3);
        box-shadow: 3px 4px 10px rgba(0,0,0,0.3);
    }
    .artist-name { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.4rem; color: #2a1f1a; }
</style>
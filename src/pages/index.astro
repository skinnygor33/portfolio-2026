---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Macarena Arriaga">
  
  <main class="min-h-screen flex flex-col justify-center items-center px-4 relative overflow-hidden text-center selection:bg-velvet selection:text-paper">
    
    <!-- Faded ash-brown / sun-bleached film base -->
    <div class="absolute inset-0 -z-30 wood-base"></div>

    <!-- Film grain -->
    <div class="absolute inset-0 -z-30 woodgrain" aria-hidden="true"></div>

    <!-- Vignette -->
    <div class="absolute inset-0 pointer-events-none -z-20 bg-[radial-gradient(circle_at_center,_transparent_15%,_rgba(20,14,10,0.45)_100%)] vignette-breathe"></div>

    <!-- Drifting dust/fog -->
    <div class="fog pointer-events-none absolute inset-0 -z-20 overflow-hidden" aria-hidden="true">
      <span class="fog-blob fog-blob--1"></span>
      <span class="fog-blob fog-blob--2"></span>
      <span class="fog-blob fog-blob--3"></span>
    </div>

    <!-- Breathing spotlight behind the name -->
    <div class="spotlight pointer-events-none absolute inset-0 -z-10 flex items-center justify-center" aria-hidden="true">
      <div class="spotlight-glow"></div>
    </div>

    <!-- Dust motes -->
    <div class="embers pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <span class="ember" style="left:8%; animation-delay:0s; animation-duration:9s;"></span>
      <span class="ember" style="left:18%; animation-delay:2.2s; animation-duration:11s;"></span>
      <span class="ember" style="left:27%; animation-delay:4.5s; animation-duration:8s;"></span>
      <span class="ember" style="left:39%; animation-delay:1.1s; animation-duration:12s;"></span>
      <span class="ember" style="left:52%; animation-delay:3.3s; animation-duration:9.5s;"></span>
      <span class="ember" style="left:64%; animation-delay:0.6s; animation-duration:10.5s;"></span>
      <span class="ember" style="left:73%; animation-delay:5.1s; animation-duration:8.5s;"></span>
      <span class="ember" style="left:84%; animation-delay:2.8s; animation-duration:11.5s;"></span>
      <span class="ember" style="left:92%; animation-delay:4s; animation-duration:9.2s;"></span>
    </div>

    <!-- Light rays through dust -->
    <div class="light-rays pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <span class="ray ray--1"></span>
      <span class="ray ray--2"></span>
    </div>

    <!-- Drifting moths -->
    <div class="moths pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <svg class="moth moth--1" viewBox="0 0 20 14" width="16">
        <path d="M10,7 C6,2 0,3 2,7 C0,11 6,12 10,7 C14,12 20,11 18,7 C20,3 14,2 10,7 Z" />
      </svg>
      <svg class="moth moth--2" viewBox="0 0 20 14" width="12">
        <path d="M10,7 C6,2 0,3 2,7 C0,11 6,12 10,7 C14,12 20,11 18,7 C20,3 14,2 10,7 Z" />
      </svg>
    </div>

    <!-- Film scratches -->
    <div class="scratches pointer-events-none absolute inset-0 -z-10 opacity-[0.06]" aria-hidden="true"></div>

    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <filter id="torn-edge" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence type="fractalNoise" baseFrequency="0.045" numOctaves="3" seed="7" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="9" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </svg>

    <div class="mb-14 animate-fade-in-up delay-2">
      <p class="font-heading text-xs tracking-[0.35em] uppercase">
        Portfolio '26
      </p>
      <svg class="flourish mx-auto mt-3" width="90" height="14" viewBox="0 0 90 14" aria-hidden="true">
      </svg>
    </div>

    <h1 id="hero-name" class="opacity-90 min-h-[3.8em] md:min-h-[2.8em] w-full max-w-4xl">
      <span class="sr-only">Macarena Arriaga</span>
    </h1>

    <nav class="mt-20 flex flex-col md:flex-row gap-8 md:gap-14 font-heading text-xs md:text-sm tracking-[0.2em] uppercase items-center animate-fade-in-up delay-5">
        
        <a href="/about" class="nav-item">About Me</a>
        <a href="/work" class="nav-item">Experience</a>
        <a href="/contact" class="nav-item">Contact</a>

        <span class="nav-divider hidden md:inline-block">|</span>

        <a href="https://www.linkedin.com/in/emilia-arriaga-0a7a632b2" target="_blank" class="nav-item">Linkedin</a>
        <a href="https://github.com/skinnygor33" target="_blank" class="nav-item">Github</a>
    </nav>

  </main>
</Layout>

<style is:global>
  .animate-fade-in-up {
    opacity: 0; 
    transform: translateY(30px); 
    animation: fadeInUp 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  .delay-2 { animation-delay: 0.3s; } 
  .delay-5 { animation-delay: 3.3s; } 

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- Faded ash-brown / sun-bleached film base ---- */
  .wood-base {
    background:
      radial-gradient(ellipse 90% 70% at 25% 15%, rgba(90,70,55,0.35), transparent 65%),
      radial-gradient(ellipse 80% 60% at 80% 85%, rgba(40,28,22,0.4), transparent 65%),
      linear-gradient(165deg, #6b5644 0%, #574636 32%, #453626 62%, #362a1e 100%);
  }

  .woodgrain {
    opacity: 0.15;
    mix-blend-mode: overlay;
    background-image:
      repeating-linear-gradient(179deg,
        rgba(0,0,0,0.4) 0px,
        rgba(0,0,0,0.4) 1px,
        transparent 1px,
        transparent 3px),
      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.05), transparent 40%),
      radial-gradient(circle at 75% 70%, rgba(255,255,255,0.04), transparent 45%);
    animation: grainDrift 45s linear infinite;
  }
  @keyframes grainDrift {
    0% { background-position: 0 0, 0 0, 0 0; }
    100% { background-position: 0 -500px, 20px 30px, -15px -20px; }
  }

  .vignette-breathe {
    animation: vignetteBreathe 9s ease-in-out infinite;
  }
  @keyframes vignetteBreathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* ---- Drifting dust / heat haze ---- */
  .fog-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(75px);
    opacity: 0.22;
    mix-blend-mode: soft-light;
  }
  .fog-blob--1 {
    width: 45vw;
    height: 45vw;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, rgba(210,180,140,0.5), transparent 70%);
    animation: driftA 26s ease-in-out infinite;
  }
  .fog-blob--2 {
    width: 40vw;
    height: 40vw;
    bottom: -15%;
    right: -10%;
    background: radial-gradient(circle, rgba(70,50,35,0.5), transparent 70%);
    animation: driftB 32s ease-in-out infinite;
  }
  .fog-blob--3 {
    width: 35vw;
    height: 35vw;
    top: 40%;
    left: 55%;
    background: radial-gradient(circle, rgba(150,115,80,0.4), transparent 70%);
    animation: driftC 22s ease-in-out infinite;
  }
  @keyframes driftA {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(6vw, 4vh) scale(1.1); }
    66% { transform: translate(-3vw, 7vh) scale(0.95); }
  }
  @keyframes driftB {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-5vw, -6vh) scale(1.08); }
    66% { transform: translate(4vw, -3vh) scale(0.97); }
  }
  @keyframes driftC {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-6vw, 5vh) scale(1.12); }
  }

  /* ---- Breathing spotlight behind the name ---- */
  .spotlight-glow {
    width: min(70vw, 900px);
    height: min(50vw, 600px);
    background: radial-gradient(ellipse at center, rgba(230,210,180,0.4) 0%, rgba(230,210,180,0.12) 35%, transparent 70%);
    filter: blur(10px);
    animation: spotlightBreathe 6s ease-in-out infinite;
  }
  @keyframes spotlightBreathe {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.06); }
  }

  /* ---- Dust motes ---- */
  .embers { overflow: hidden; }
  .ember {
    position: absolute;
    bottom: -5%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(230,210,180,0.85) 0%, rgba(180,150,110,0.25) 70%, transparent 100%);
    filter: blur(0.5px);
    animation-name: emberRise;
    animation-timing-function: cubic-bezier(0.4, 0, 0.6, 1);
    animation-iteration-count: infinite;
    opacity: 0;
  }
  @keyframes emberRise {
    0%   { transform: translateY(0) translateX(0); opacity: 0; }
    10%  { opacity: 0.7; }
    50%  { transform: translateY(-45vh) translateX(15px); opacity: 0.5; }
    90%  { opacity: 0.15; }
    100% { transform: translateY(-95vh) translateX(-10px); opacity: 0; }
  }

  /* ---- Light rays ---- */
  .ray {
    position: absolute;
    top: -20%;
    width: 140px;
    height: 160%;
    background: linear-gradient(180deg, rgba(255,235,200,0.12), transparent 70%);
    transform-origin: top center;
    filter: blur(6px);
  }
  .ray--1 {
    left: 15%;
    transform: rotate(12deg);
    animation: raySway 14s ease-in-out infinite;
  }
  .ray--2 {
    right: 20%;
    transform: rotate(-10deg);
    animation: raySway 18s ease-in-out infinite reverse;
  }
  @keyframes raySway {
    0%, 100% { opacity: 0.5; transform: rotate(12deg) translateX(0); }
    50% { opacity: 0.85; transform: rotate(9deg) translateX(20px); }
  }

  /* ---- Moths ---- */
  .moth {
    position: absolute;
    opacity: 0;
  }
  .moth path {
    fill: #e6ddc4;
    opacity: 0.5;
  }
  .moth--1 {
    top: 30%;
    left: 10%;
    animation: mothFlutter1 19s ease-in-out infinite;
  }
  .moth--2 {
    top: 65%;
    right: 15%;
    animation: mothFlutter2 23s ease-in-out infinite 4s;
  }
  @keyframes mothFlutter1 {
    0% { opacity: 0; transform: translate(0,0) rotate(0deg); }
    10% { opacity: 0.6; }
    30% { transform: translate(15vw, -8vh) rotate(15deg); }
    50% { transform: translate(25vw, 5vh) rotate(-10deg); }
    70% { transform: translate(10vw, 15vh) rotate(20deg); opacity: 0.5; }
    90% { opacity: 0; }
    100% { opacity: 0; transform: translate(30vw, -5vh) rotate(0deg); }
  }
  @keyframes mothFlutter2 {
    0% { opacity: 0; transform: translate(0,0) rotate(0deg); }
    12% { opacity: 0.5; }
    35% { transform: translate(-18vw, -10vh) rotate(-15deg); }
    55% { transform: translate(-8vw, 8vh) rotate(12deg); }
    75% { transform: translate(-22vw, 4vh) rotate(-8deg); opacity: 0.4; }
    92% { opacity: 0; }
    100% { opacity: 0; transform: translate(-30vw, -6vh) rotate(0deg); }
  }

  /* ---- Film scratches ---- */
  .scratches {
    background-image:
      repeating-linear-gradient(90deg, transparent 0px, transparent 120px, rgba(255,255,255,0.6) 121px, transparent 123px),
      repeating-linear-gradient(88deg, transparent 0px, transparent 280px, rgba(0,0,0,0.5) 281px, transparent 283px);
    mix-blend-mode: overlay;
    animation: scratchFlicker 0.3s steps(2) infinite;
  }
  @keyframes scratchFlicker {
    0%, 100% { opacity: 0.06; }
    50% { opacity: 0.12; }
  }

  /* ---- Title / nav: legible gothic-editorial serif, backlit glow ---- */
  .font-heading {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    color: #f2e9d4;
    letter-spacing: 0.08em;
    text-shadow:
      0 0 18px rgba(230, 200, 150, 0.35),
      0 0 4px rgba(0,0,0,0.5),
      0 2px 4px rgba(0,0,0,0.5);
  }

  .flourish path,
  .flourish circle {
    stroke: #d9a4a0;
    fill: none;
    stroke-width: 1;
    opacity: 0.6;
  }
  .flourish circle {
    fill: #d9a4a0;
    stroke: none;
  }

  .nav-divider {
    color: rgba(230, 221, 196, 0.25);
  }

  .nav-item {
    position: relative;
    display: inline-block;
    color: #f2e9d4;
    padding: 0.25em 0.15em;
    text-shadow: 0 0 10px rgba(230, 200, 150, 0.25), 0 1px 3px rgba(0,0,0,0.5);
    transition: color 0.4s ease, transform 0.4s ease, text-shadow 0.4s ease;
  }
  .nav-item:hover {
    color: #fff8e8;
    transform: translateY(-2px);
    text-shadow: 0 0 20px rgba(230, 200, 150, 0.55), 0 1px 3px rgba(0,0,0,0.5);
  }

  /* ---- Ransom-note name ---- */
  #hero-name .glyph-line {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: nowrap;
    gap: 1.1em 0.85em;
    margin-bottom: 0.7em;
    font-size: 2.1rem;
  }

  @media (min-width: 768px) {
    #hero-name .glyph-line { font-size: 3.75rem; }
  }

  #hero-name .glyph-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 1.4em;
    height: 1.55em;
    flex-shrink: 0;
    filter: blur(14px);
    opacity: 0;
    transform: translateY(-8px) scale(0.85);
  }

  #hero-name .glyph-wrap.scrambling {
    animation: scrambleWobble 0.9s ease-in-out infinite;
  }
  @keyframes scrambleWobble {
    0%, 100% { transform: translateY(-8px) rotate(-2deg) scale(0.9); filter: blur(10px); opacity: 0.35; }
    30% { transform: translateY(-4px) rotate(1.5deg) scale(0.95); filter: blur(6px); opacity: 0.55; }
    60% { transform: translateY(-6px) rotate(-1deg) scale(0.92); filter: blur(8px); opacity: 0.45; }
  }

  #hero-name .glyph-wrap.settling {
    filter: blur(3px);
    opacity: 0.75;
  }

  #hero-name .glyph-wrap.settled {
    filter: blur(0);
    opacity: 1;
    animation: paperSettle 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  #hero-name .scrap {
    position: absolute;
    inset: -14% -10%;
    background-color: var(--scrap-bg);
    background-image:
      repeating-linear-gradient(112deg, rgba(0,0,0,0.05) 0px, rgba(0,0,0,0.05) 1px, transparent 1px, transparent 4px),
      repeating-linear-gradient(24deg, rgba(0,0,0,0.03) 0px, rgba(0,0,0,0.03) 1px, transparent 1px, transparent 6px),
      radial-gradient(ellipse 40% 30% at 20% 25%, rgba(70,45,25,0.10), transparent 70%),
      radial-gradient(ellipse 35% 25% at 80% 75%, rgba(70,45,25,0.08), transparent 70%),
      radial-gradient(ellipse 50% 40% at 60% 15%, rgba(255,255,255,0.18), transparent 70%),
      radial-gradient(ellipse 90% 90% at 50% 50%, transparent 55%, rgba(20,12,8,0.12) 100%);
    filter: url(#torn-edge);
    box-shadow:
      3px 5px 9px rgba(15, 8, 8, 0.5),
      0 0 0 1px rgba(15, 8, 8, 0.06) inset;
    z-index: 0;
  }

  #hero-name .glyph-wrap.creased .scrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(var(--crease-angle), transparent 48%, rgba(0,0,0,0.09) 50%, transparent 52%);
  }

  #hero-name .glyph {
    position: relative;
    z-index: 1;
    display: inline-block;
    color: var(--scrap-color);
    font-family: var(--scrap-font);
    line-height: 1;
    text-shadow: 0.5px 0.5px 0 rgba(0,0,0,0.15);
  }

  @keyframes paperSettle {
    0%   { transform: translateY(-10px) rotate(0deg) scale(1.22); }
    35%  { transform: translateY(3px) rotate(var(--rot)) scale(0.95); }
    55%  { transform: translateY(-2px) rotate(calc(var(--rot) - 1.5deg)) scale(1.02); }
    75%  { transform: translateY(1px) rotate(calc(var(--rot) + 0.8deg)) scale(0.99); }
    100% { transform: translateY(0) rotate(var(--rot)) scale(1); }
  }

  #hero-name .glyph-wrap.gust {
    animation: gustShake 0.6s ease-in-out;
  }
  @keyframes gustShake {
    0%   { transform: translateY(0) rotate(var(--rot)) scale(1); }
    25%  { transform: translateY(-3px) rotate(calc(var(--rot) - 3deg)) scale(1.03); }
    50%  { transform: translateY(1px) rotate(calc(var(--rot) + 2deg)) scale(0.99); }
    75%  { transform: translateY(-1px) rotate(calc(var(--rot) - 1deg)) scale(1.01); }
    100% { transform: translateY(0) rotate(var(--rot)) scale(1); }
  }

  #hero-name.name-flicker {
    animation: nameFlicker 7s ease-in-out infinite;
  }
  @keyframes nameFlicker {
    0%, 100% { opacity: 0.92; }
    6%  { opacity: 0.8; }
    11% { opacity: 0.95; }
    38% { opacity: 0.88; }
    47% { opacity: 0.97; }
    68% { opacity: 0.85; }
    82% { opacity: 0.95; }
  }
</style>

<script>
  function initScramble() {
    const el = document.getElementById('hero-name');
    if (!el || el.dataset.decoded === 'true') return;
    el.dataset.decoded = 'true';

    const lines = ['Macarena', 'Arriaga'];
    const glyphPool = '!<>-_\\/[]{}=+*^?#✝†⚰✦⛧✞○●'.split('');

    const fontPool = [
      "'Cormorant Garamond', serif",
      "'UnifrakturMaguntia', cursive",
      "'Special Elite', monospace",
      "'Playfair Display', serif",
      "'IM Fell English', serif",
    ];
    const inkPool = ['#5c1a1f', '#2a2422', '#1c1c1c', '#22403f', '#3b2340'];
    const paperPool = ['#e9dfc6', '#ded0ac', '#e2d3b8', '#d9c9a8', '#e6ddc4', '#cfc2a0'];

    el.innerHTML = '';
    const spans = [];
    let globalIndex = 0;

    lines.forEach((word) => {
      const lineEl = document.createElement('span');
      lineEl.className = 'glyph-line';

      word.split('').forEach((char) => {
        const wrap = document.createElement('span');
        wrap.className = 'glyph-wrap';

        const rot = (Math.random() * 10 - 5).toFixed(1) + 'deg';
        wrap.style.setProperty('--rot', rot);
        wrap.style.setProperty('--scrap-bg', paperPool[Math.floor(Math.random() * paperPool.length)]);
        wrap.style.setProperty('--scrap-color', inkPool[Math.floor(Math.random() * inkPool.length)]);
        wrap.style.setProperty('--scrap-font', fontPool[Math.floor(Math.random() * fontPool.length)]);

        if (Math.random() > 0.6) {
          wrap.classList.add('creased');
          wrap.style.setProperty('--crease-angle', Math.random() > 0.5 ? '95deg' : '15deg');
        }

        const scrap = document.createElement('span');
        scrap.className = 'scrap';
        scrap.setAttribute('aria-hidden', 'true');

        const glyph = document.createElement('span');
        glyph.className = 'glyph';
        glyph.textContent = glyphPool[Math.floor(Math.random() * glyphPool.length)];

        wrap.appendChild(scrap);
        wrap.appendChild(glyph);
        lineEl.appendChild(wrap);

        spans.push({ wrap, glyph, finalChar: char, order: globalIndex });
        globalIndex++;
      });

      el.appendChild(lineEl);
    });

    function runGlyph({ wrap, glyph, finalChar, order }) {
      const startDelay = 450 + order * 200 + Math.random() * 180;
      const wobbleDuration = 650 + Math.random() * 350;

      setTimeout(() => {
        wrap.classList.add('scrambling');

        const swaps = 2 + Math.floor(Math.random() * 2);
        for (let i = 1; i <= swaps; i++) {
          setTimeout(() => {
            glyph.textContent = glyphPool[Math.floor(Math.random() * glyphPool.length)];
          }, (wobbleDuration / (swaps + 1)) * i);
        }

        setTimeout(() => {
          wrap.classList.remove('scrambling');
          wrap.classList.add('settling');
          glyph.textContent = finalChar;

          setTimeout(() => {
            wrap.classList.remove('settling');
            wrap.classList.add('settled');
          }, 80);
        }, wobbleDuration);
      }, startDelay);
    }

    spans.forEach(runGlyph);

    const totalDuration = 450 + spans.length * 200 + 1600;

    setTimeout(() => {
      el.classList.add('name-flicker');
      startGusts();
    }, totalDuration);

    function startGusts() {
      function scheduleGust() {
        const delay = 5000 + Math.random() * 7000;
        setTimeout(() => {
          const count = 1 + Math.floor(Math.random() * 2);
          for (let i = 0; i < count; i++) {
            const target = spans[Math.floor(Math.random() * spans.length)].wrap;
            target.classList.remove('gust');
            void target.offsetWidth;
            target.classList.add('gust');
          }
          scheduleGust();
        }, delay);
      }
      scheduleGust();
    }
  }

  initScramble();
  document.addEventListener('astro:page-load', initScramble);
</script>